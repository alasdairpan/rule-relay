# Public Shadowsocks listener.
SS_SERVER_PORT=8388
# Shared secret for the proxy transport. Replace with a long random value.
SS_SERVER_PASSWORD=replace-with-generated-key

# Bearer token required by the relay API.
RELAY_AUTH_TOKEN=replace-with-long-random-token
# Host port used for local relay access.
RELAY_PORT=8080
# Loopback-bound AdGuard Home admin UI.
ADGUARD_ADMIN_PORT=3000
# AdGuard Home credentials used by the relay for control API access after setup.
ADGUARD_USERNAME=
ADGUARD_PASSWORD=

# Cache TTLs exposed by the relay API. Allowed domains generally use shorter TTLs
# than blocked domains so updated filter lists propagate faster.
RELAY_ALLOWED_TTL_SECS=3600
RELAY_BLOCKED_TTL_SECS=86400